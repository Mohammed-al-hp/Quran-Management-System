@page
@model LoginModel

@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null; // لا نريد استخدام الـ Layout العام هنا
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - منظومة إتقان</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            /* خلفية بتدرج لوني داكن وفخم مستوحاة من image_0.png */
            background: linear-gradient(135deg, #1e293b 0%, #1a531a 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background-color: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 900px;
            max-width: 95%;
            display: flex;
        }

        /* الجزء الأيمن (الداكن والشعار) مستوحى من image_0.png */
        .login-right {
            background-color: #1e293b;
            color: white;
            width: 50%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-center;
        }

        /* الجزء الأيسر (نموذج تسجيل الدخول) مستوحى من image_0.png */
        .login-left {
            width: 50%;
            padding: 50px;
        }

        .form-control-custom {
            border-radius: 30px;
            padding: 12px 20px;
            border: 1px solid #e2e8f0;
            margin-bottom: 20px;
        }

        .btn-login {
            border-radius: 30px;
            padding: 12px;
            background-color: var(--primary-green);
            color: white;
            font-weight: bold;
            border: none;
            width: 100%;
        }

            .btn-login:hover {
                background-color: var(--secondary-green);
            }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-right border-start border-gold border-4">
            <i class="bi bi-book-half" style="font-size: 5rem; color: var(--accent-gold);"></i>
            <h2 class="mt-4 fw-bold">منظومة إتقان</h2>
            <p class="text-muted mt-2">لتحفيظ القرآن الكريم - مصراتة</p>
        </div>

        <div class="login-left">
            <h3 class="fw-bold text-dark mb-2">تسجيل الدخول</h3>
            <p class="text-muted mb-4">أدخل بياناتك للوصول إلى لوحة التحكم</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-group position-relative">
                    <i class="bi bi-person text-muted position-absolute" style="top: 15px; right: 20px; font-size: 1.2rem;"></i>
                    <input asp-for="Input.Email" class="form-control form-control-custom pe-5" autocomplete="username" aria-required="true" placeholder="اسم المستخدم (البريد الإكتروني)" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group position-relative">
                    <i class="bi bi-lock text-muted position-absolute" style="top: 15px; right: 20px; font-size: 1.2rem;"></i>
                    <input asp-for="Input.Password" class="form-control form-control-custom pe-5" autocomplete="current-password" aria-required="true" placeholder="كلمة المرور" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-group d-flex justify-content-between mb-4 mt-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label text-muted" asp-for="Input.RememberMe">تذكرني</label>
                    </div>
                    <a href="#" class="text-decoration-none text-success btn-sm p-0">نسيت كلمة المرور؟</a>
                </div>

                <button id="login-submit" type="submit" class="btn-login">دخول</button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>