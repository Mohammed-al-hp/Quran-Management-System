@page
@model LoginModel

@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null; // لا نريد استخدام الـ Layout العام هنا
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - منظومة إتقان</title>

    @* استيراد خط Cairo لضمان توحيد الخط مع باقي الصفحات *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-green: #1a531a;
            --secondary-green: #2a752a;
            --accent-gold: #c9a050;
        }

        body {
            /* تطبيق خط Cairo */
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, #1e293b 0%, #1a531a 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background-color: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 900px;
            max-width: 95%;
            display: flex;
        }

        .login-right {
            background-color: #1e293b;
            color: white;
            width: 50%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .login-left {
            width: 50%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* تنسيق العناوين في المنتصف كما طلبت */
        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .form-control-custom {
            border-radius: 30px;
            padding: 12px 20px;
            border: 1px solid #e2e8f0;
            margin-bottom: 10px;
            font-size: 0.9rem;
        }

        .btn-login {
            border-radius: 30px;
            padding: 12px;
            background-color: var(--primary-green);
            color: white;
            font-weight: bold;
            border: none;
            width: 100%;
            transition: all 0.3s ease;
        }

            .btn-login:hover {
                background-color: var(--secondary-green);
                transform: translateY(-2px);
            }

        .border-gold {
            border-color: var(--accent-gold) !important;
        }

        /* لضمان ظهور الأيقونات بشكل صحيح داخل الحقول */
        .input-icon {
            top: 13px;
            right: 20px;
            z-index: 10;
        }
    </style>
</head>
<body>
    <div class="login-card">
        @* الجزء الأيمن (الشعار والاسم) *@
        <div class="login-right border-start border-gold border-4 d-none d-md-flex">
            <i class="bi bi-book-half" style="font-size: 5rem; color: var(--accent-gold);"></i>
            <h2 class="mt-4 fw-bold">منظومة إتقان</h2>
            <p class="text-white-50 mt-2">لتحفيظ القرآن الكريم - مصراتة</p>
        </div>

        @* الجزء الأيسر (نموذج الدخول) *@
        <div class="login-left">
            @* وضعنا العناوين داخل div لضمان التوسيط *@
            <div class="login-header">
                <h3 class="fw-bold text-dark mb-2">تسجيل الدخول</h3>
                <p class="text-muted small">أدخل بياناتك للوصول إلى لوحة التحكم</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-group position-relative mb-3">
                    <i class="bi bi-person text-muted position-absolute input-icon"></i>
                    <input asp-for="Input.Email" class="form-control form-control-custom pe-5" autocomplete="username" aria-required="true" placeholder="البريد الإلكتروني" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-group position-relative mb-3">
                    <i class="bi bi-lock text-muted position-absolute input-icon"></i>
                    <input asp-for="Input.Password" class="form-control form-control-custom pe-5" autocomplete="current-password" aria-required="true" placeholder="كلمة المرور" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4 mt-2 px-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label text-muted small" asp-for="Input.RememberMe">تذكرني</label>
                    </div>
                    <a href="#" class="text-decoration-none text-success small">نسيت كلمة المرور؟</a>
                </div>

                <button id="login-submit" type="submit" class="btn-login">دخول</button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>