@model QuranCenters.Core.Entities.Student

@{
    ViewData["Title"] = "????? ?????? ?????";
    var memorizations = ViewBag.Memorizations as List<QuranCenters.Core.Entities.Memorization>;
}

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h4 class="text-success fw-bold m-0">????? ?????? ????? ?????????</h4>
            <small class="text-muted">?????? ????? ?????? ?????? ??????</small>
        </div>
        <button class="btn btn-gold" onclick="window.print()">
            <i class="bi bi-printer"></i> ????? ???????
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white rounded-3">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-2 text-center">
                    <div class="bg-light p-4 rounded-circle d-inline-block">
                        <i class="bi bi-person-bounding-box text-success" style="font-size: 3.5rem;"></i>
                    </div>
                </div>
                <div class="col-md-5">
                    <h3 class="fw-bold text-dark mb-1">@Model.Name</h3>
                    <p class="text-muted mb-2">????? ????????: @Model.JoinDate.ToShortDateString()</p>
                    <span class="badge @(Model.Status == "???" ? "bg-success" : "bg-secondary") rounded-pill px-3 py-2">
                        @Model.Status
                    </span>
                </div>
                <div class="col-md-5 border-start">
                    <div class="ps-4">
                        <p class="mb-2"><strong>?????? ???????:</strong> @(Model.Circle?.Name ?? "??? ????")</p>

                        @* ??????? ???: ??? ?????? ?? ???? ?????? ???????? ??????? *@
                        <p class="mb-2"><strong>?????? ??????:</strong> @(Model.Circle?.Teacher?.Name ?? "??? ????")</p>

                        <p class="mb-0"><strong>??? ???? ?????? ??? ?????:</strong> 22 ??? (????)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 bg-white rounded-3">
        <div class="card-header bg-white border-bottom p-4">
            <h5 class="fw-bold text-dark m-0">??? ??????? ????????? ??????</h5>
        </div>
        <div class="card-body p-0">
            @if (memorizations != null && memorizations.Any())
            {
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3">???????</th>
                            <th class="py-3">??????</th>
                            <th class="py-3">?? ???</th>
                            <th class="py-3">??? ???</th>
                            <th class="py-3">???????</th>
                            <th class="py-3">??????? ??????</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in memorizations)
                        {
                            <tr>
                                <td>@item.Date.ToShortDateString()</td>
                                <td class="fw-bold text-success">@item.SurahName</td>
                                <td>@item.FromAyah</td>
                                <td>@item.ToAyah</td>
                                <td>
                                    @if (item.Grade == "?????")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">@item.Grade</span>
                                    }
                                    else if (item.Grade == "??? ????")
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">@item.Grade</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">@item.Grade</span>
                                    }
                                </td>
                                <td class="text-muted">@item.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center p-5">
                    <i class="bi bi-folder-x text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-2">?? ???? ????? ????? ????? ???? ?????? ??? ????.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    @@media print {
        .sidebar, .top-header, .btn-gold, .btn-group, .text-end {
            display: none !important;
        }

        .main-content {
            margin-right: 0 !important;
            padding: 0 !important;
        }

        .card {
            border: 1px solid #ddd !important;
            box-shadow: none !important;
        }
    }
</style>