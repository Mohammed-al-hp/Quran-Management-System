                            <tr>
                                <td>@item.Date.ToShortDateString()</td>
                                <td class="fw-bold">@(item.Student?.Name ?? "??? ????")</td>
                                <td>
                                    @if (item.Status == "????")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">????</span>
                                    }
                                    else if (item.Status == "????")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">????</span>
