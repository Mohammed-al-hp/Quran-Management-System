@model IEnumerable<QuranCentersSystem.Models.Student>

@{
    ViewData["Title"] = "تسجيل الحضور الجماعي";
}

<div class="container-fluid" dir="rtl">
    <div class="card shadow-sm border-0 mb-4 bg-white rounded-3">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                <div>
                    <h4 class="text-success fw-bold m-0">تسجيل الحضور الجماعي بالحلقة</h4>
                    <small class="text-muted">اختر الحلقة وسجل حضور جميع طلابها دفعة واحدة</small>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">عودة للسجل</a>
            </div>

            <form method="get" asp-action="GroupAttendance" class="row g-3 align-items-end mb-4 bg-light p-3 rounded-3 border">
                <div class="col-md-5">
                    <label class="form-label fw-bold text-secondary">اختر الحلقة القرآنية</label>
                    <select name="circleId" class="form-select" asp-items="ViewBag.Circles" onchange="this.form.submit()">
                        <option value="">-- اختر الحلقة لعرض الطلاب --</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold text-secondary">التاريخ</label>
                    <input type="date" id="attendanceDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" readonly />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">عرض الطلاب</button>
                </div>
            </form>

            @if (ViewBag.SelectedCircleId != null && Model != null)
            {
                if (!Model.Any())
                {
                    <div class="alert alert-warning text-center my-4" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i> لا يوجد طلاب مضافين في هذه الحلقة حتى الآن!
                    </div>
                }
                else
                {
                    <form asp-action="SaveGroupAttendance" method="post">
                        <input type="hidden" name="circleId" value="@ViewBag.SelectedCircleId" />
                        <input type="hidden" name="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th class="py-3">اسم الطالب</th>
                                        <th class="py-3 text-center" style="width: 300px;">حالة الحضور اليوم</th>
                                        <th class="py-3">ملاحظات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var student in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold">@student.Name</td>
                                            <td>
                                                <div class="btn-group w-100" role="group">
                                                    <input type="radio" class="btn-check" name="attendanceStatus[@student.Id]" id="present_@student.Id" value="حاضر" checked>
                                                    <label class="btn btn-outline-success" for="present_@student.Id">حاضر</label>

                                                    <input type="radio" class="btn-check" name="attendanceStatus[@student.Id]" id="absent_@student.Id" value="غائب">
                                                    <label class="btn btn-outline-danger" for="absent_@student.Id">غائب</label>

                                                    <input type="radio" class="btn-check" name="attendanceStatus[@student.Id]" id="excused_@student.Id" value="مستأذن">
                                                    <label class="btn btn-outline-warning" for="excused_@student.Id">مستأذن</label>
                                                </div>
                                            </td>
                                            <td>
                                                <input type="text" name="notes[@student.Id]" class="form-control form-control-sm" placeholder="أضف ملاحظة إن وجدت..." />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success btn-lg">حفظ سجل الحضور بالكامل</button>
                        </div>
                    </form>
                }
            }
        </div>
    </div>
</div>