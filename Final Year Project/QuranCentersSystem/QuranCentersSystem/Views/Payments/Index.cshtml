@model IEnumerable<QuranCenters.Core.Entities.Payment>

<div class="container py-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-primary mb-0">??????? ???????</h3>
            <p class="text-muted small">?????? ???? ????????? ??????? ????????</p>
        </div>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> ????? ??? ????
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white rounded-4 p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 rounded-circle p-3 me-3">
                        <i class="bi bi-wallet2 fs-4"></i>
                    </div>
                    <div>
                        <div class="small opacity-75">?????? ??????</div>
                        <h4 class="fw-bold mb-0">@Model.Sum(p => p.Amount).ToString("N2") ?.?</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white rounded-4 p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 rounded-circle p-3 me-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <div class="small opacity-75">??? ???????</div>
                        <h4 class="fw-bold mb-0">@Model.Count()</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 px-4 py-3">??????</th>
                        <th class="border-0 py-3 text-center">??????</th>
                        <th class="border-0 py-3 text-center">???????</th>
                        <th class="border-0 py-3 text-center">??? ??????</th>
                        <th class="border-0 py-3 text-center">??????</th>
                        <th class="border-0 px-4 py-3 text-end">?????????</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4">
                                <div class="fw-bold text-dark">@item.Student.Name</div>
                            </td>
                            <td class="text-center fw-bold text-success">
                                @item.Amount.ToString("N2")
                            </td>
                            <td class="text-center text-muted">
                                @item.PaymentDate.ToShortDateString()
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-info text-info rounded-pill px-3">@item.PaymentType</span>
                            </td>
                            <td class="text-center small text-secondary">
                                @item.CreatedBy
                            </td>
                            <td class="px-4 text-end">
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    <a class="btn btn-sm btn-white text-primary border-end"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-sm btn-white text-danger"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-info {
        background-color: #e0f7fa;
    }

    .btn-white {
        background: white;
        border: 1px solid #eee;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }
</style>