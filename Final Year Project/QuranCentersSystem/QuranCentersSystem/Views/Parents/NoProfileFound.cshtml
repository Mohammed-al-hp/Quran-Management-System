@{
    ViewData["Title"] = "لم يتم العثور على ملف";
}

<div class="container py-5" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="bg-warning py-5">
                    <i class="bi bi-person-x-fill display-1 text-white"></i>
                </div>
                <div class="card-body p-5">
                    <h2 class="fw-bold text-dark mb-4">عذراً، لم نتمكن من العثور على بياناتك</h2>
                    <p class="text-muted fs-5 mb-5">
                        الحساب الذي سجلت الدخول به غير مرتبط بأي ملف "ولي أمر" في النظام حالياً. 
                        يرجى التأكد من أن البريد الإلكتروني المستخدم هو نفس البريد المسجل لدى إدارة المركز.
                    </p>
                    
                    <div class="alert alert-info border-0 shadow-sm mb-5">
                        <i class="bi bi-info-circle me-2"></i>
                        إذا كنت قد سجلت مؤخراً، فقد يحتاج المسؤول لبعض الوقت لربط حسابك ببيانات أبنائك.
                    </div>

                    <div class="d-flex gap-3 justify-content-center">
                        <a href="mailto:admin@quransystems.com" class="btn btn-primary px-4 py-2 rounded-pill">
                            <i class="bi bi-envelope me-1"></i> مراسلة الإدارة
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                            <i class="bi bi-house-door me-1"></i> العودة للرئيسية
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-light py-3">
                    <small class="text-muted">نظام إتقان لإدارة المراكز القرآنية - @DateTime.Now.Year</small>
                </div>
            </div>
        </div>
    </div>
</div>
