@model IEnumerable<QuranCenters.Core.Entities.Circle>

@{
    ViewData["Title"] = "الحلقات الدراسية";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="card shadow-sm bg-white p-4 rounded-3 border-0">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <div>
                <h4 class="m-0 text-success fw-bold">إدارة الحلقات</h4>
                <p class="text-muted small mb-0">قائمة الحلقات الدراسية والمحفظين المسؤولين عنها</p>
            </div>
            <a asp-controller="Circles" asp-action="Create" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-plus-circle"></i> إضافة حلقة جديدة
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light text-center">
                    <tr>
                        <th class="py-3">اسم الحلقة</th>
                        <th class="py-3">المحفظ المسؤول</th>
                        <th class="py-3">عدد الطلاب</th>
                        <th class="py-3">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td class="text-primary fw-medium">@(item.Teacher?.Name ?? "غير محدد")</td>
                            <td>
                                <span class="badge bg-light text-success border">
                                    @(item.Students?.Count() ?? 0) طالب
                                </span>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 shadow-xs">
                                        <i class="bi bi-pencil me-1"></i> تعديل
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3 shadow-xs">
                                        <i class="bi bi-eye me-1"></i> عرض
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>