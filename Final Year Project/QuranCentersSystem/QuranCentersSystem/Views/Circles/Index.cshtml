@model IEnumerable<QuranCentersSystem.Models.Circle>

@{
    ViewData["Title"] = "إدارة الحلقات";
    var selectedGender = Context.Request.Query["gender"].ToString();
    var selectedType = Context.Request.Query["circleType"].ToString();

    // إحصائيات سريعة
    var totalCircles = Model.Count();
    var maleCircles = Model.Count(c => c.Gender == "ذكور" || c.Gender == "ذكر");
    var femaleCircles = Model.Count(c => c.Gender == "إناث" || c.Gender == "أنثى");
}

<div class="container-fluid py-4" dir="rtl">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div class="d-flex align-items-center">
            <div class="icon-box shadow-sm bg-white rounded-3 d-flex align-items-center justify-content-center me-3"
                 style="width: 55px; height: 55px; border-bottom: 3px solid var(--bs-primary);">
                <i class="bi bi-mortarboard-fill text-primary" style="font-size: 1.8rem;"></i>
            </div>
            <div>
                <h3 class="fw-bold text-dark mb-0" style="letter-spacing: -0.5px;">إدارة الحلقات التعليمية</h3>
                <p class="text-muted small mb-0">نظام إدارة ومتابعة حلقات التحفيظ</p>
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary px-4 py-2 shadow-sm rounded-3 fw-bold">
            <i class="bi bi-plus-lg me-1"></i> إضافة حلقة جديدة
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-3 stats-card h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3 text-primary">
                        <i class="bi bi-grid-3x3-gap-fill fs-4"></i>
                    </div>
                    <div>
                        <span class="text-muted d-block small fw-bold">إجمالي الحلقات</span>
                        <h4 class="fw-800 mb-0 mt-1">@totalCircles</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-3 stats-card h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3 text-info">
                        <i class="bi bi-gender-male fs-4"></i>
                    </div>
                    <div>
                        <span class="text-muted d-block small fw-bold">حلقات الذكور</span>
                        <h4 class="fw-800 mb-0 mt-1">@maleCircles</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-3 stats-card h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3 me-3 text-danger">
                        <i class="bi bi-gender-female fs-4"></i>
                    </div>
                    <div>
                        <span class="text-muted d-block small fw-bold">حلقات الإناث</span>
                        <h4 class="fw-800 mb-0 mt-1">@femaleCircles</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4 rounded-3">
        <div class="card-body p-3">
            <form method="get" class="row g-2 align-items-end">

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-dark">
                        <i class="bi bi-funnel me-1"></i> نوع الحلقة
                    </label>

                    <select name="circleType" class="form-select border-light-subtle shadow-none">
                        <option value="الكل">جميع الأنواع</option>
                        <option value="حلقة عامة" selected="@(selectedType == "حلقة عامة")">حلقة عامة</option>
                        <option value="دورة صيفية" selected="@(selectedType == "دورة صيفية")">دورة صيفية</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label small fw-bold text-dark">
                        <i class="bi bi-people me-1"></i> الفئة
                    </label>

                    <select name="gender" class="form-select border-light-subtle shadow-none">
                        <option value="الكل">الكل</option>
                        <option value="ذكور" selected="@(selectedGender == "ذكور")">ذكور</option>
                        <option value="إناث" selected="@(selectedGender == "إناث")">إناث</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <button type="submit" class="btn btn-dark w-100 fw-bold py-2 rounded-3">
                        <i class="bi bi-arrow-repeat me-1"></i>
                        تحديث النتائج
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">

                <thead>
                    <tr>
                        <th class="ps-4">#</th>
                        <th>اسم الحلقة</th>
                        <th>النوع</th>
                        <th>الجنس</th>
                        <th>المحفظ</th>
                        <th class="text-center">عدد الطلاب</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Any())
                    {
                        int counter = 1;

                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="ps-4 text-muted fw-bold">
                                    @counter
                                </td>

                                <td>
                                    <div class="fw-bold text-dark fs-6">
                                        @item.Name
                                    </div>
                                </td>

                                <td>
                                    <span class="badge @(item.CircleType == "دورة صيفية" ? "bg-warning text-dark" : "bg-primary-subtle text-primary") px-3 py-2 rounded-pill">
                                        @item.CircleType
                                    </span>
                                </td>

                                <td>
                                    @if (item.Gender == "ذكور" || item.Gender == "ذكر")
                                    {
                                        <span class="text-info fw-bold">
                                            <i class="bi bi-person-fill me-1"></i> ذكور
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">
                                            <i class="bi bi-person-fill-heart me-1"></i> إناث
                                        </span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2">
                                            @(item.Teacher?.Name?.Substring(0, 1) ?? "؟")
                                        </div>

                                        <span class="fw-medium">
                                            @(item.Teacher?.Name ?? "لم يحدد")
                                        </span>
                                    </div>
                                </td>

                                <td class="text-center">
                                    <span class="fw-bold text-dark bg-light px-3 py-1 rounded-3 border">
                                        @item.Students.Count
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="dropdown">

                                        <button class="btn btn-light btn-sm rounded-circle shadow-none border"
                                                data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots"></i>
                                        </button>

                                        <ul class="dropdown-menu shadow-lg border-0">

                                            <li>
                                                <a class="dropdown-item py-2"
                                                   href="javascript:void(0)"
                                                   onclick="showDetails(@item.Id)">
                                                    <i class="bi bi-search text-info me-2"></i>
                                                    التفاصيل
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item py-2"
                                                   asp-action="Edit"
                                                   asp-route-id="@item.Id">
                                                    <i class="bi bi-pencil-square text-warning me-2"></i>
                                                    تعديل
                                                </a>
                                            </li>

                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>

                                            <li>
                                                <form asp-action="Delete"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      onsubmit="return confirm('هل أنت متأكد من حذف هذه الحلقة؟');">

                                                    <button type="submit"
                                                            class="dropdown-item py-2 text-danger">
                                                        <i class="bi bi-trash3 me-2"></i>
                                                        حذف
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>

                            counter++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">

                                <div class="py-4">

                                    <i class="bi bi-search text-muted opacity-25"
                                       style="font-size: 4rem;"></i>

                                    <h5 class="mt-3 text-secondary">
                                        لا توجد حلقات مطابقة للبحث
                                    </h5>

                                    <p class="text-muted small">
                                        جرب تغيير الفلترة أو قم بإضافة حلقة جديدة
                                    </p>

                                    <a asp-action="Create"
                                       class="btn btn-outline-primary btn-sm rounded-pill px-4">
                                        <i class="bi bi-plus-lg"></i>
                                        إضافة أول حلقة
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal التفاصيل -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4" id="modalContent">

            <div class="p-5 text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">جاري التحميل...</span>
                </div>
            </div>

        </div>
    </div>
</div>

<style>

    body {
        font-family: 'Cairo', sans-serif;
    }

    .fw-800 {
        font-weight: 800;
    }

    .custom-table thead {
        background-color: #f8f9fa;
    }

        .custom-table thead th {
            font-weight: 700;
            color: #495057;
            font-size: 0.9rem;
            padding: 15px 10px;
            border-bottom: 2px solid #edf2f7;
            white-space: nowrap;
        }

    .custom-table tbody tr {
        transition: all 0.25s ease;
        border-bottom: 1px solid #f1f4f8;
    }

        .custom-table tbody tr:hover {
            background-color: #f9fbff !important;
            transform: translateY(-1px);
        }

    .avatar-circle {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, #edf4ff, #dbeafe);
        color: #2563eb;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: bold;
        border: 1px solid #dbeafe;
    }

    .stats-card {
        transition: all 0.3s ease;
    }

        .stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        }

    .badge {
        font-weight: 600;
        letter-spacing: 0.2px;
    }

    .dropdown-menu {
        min-width: 180px;
        border-radius: 14px;
    }

    .dropdown-item {
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

        .dropdown-item:hover {
            background-color: #f8f9fa;
            padding-right: 1.2rem;
        }

    @@media (max-width: 768px) {

        .custom-table {
            min-width: 800px;
        }
    }

</style>

@section Scripts {

    <script>

        function showDetails(id) {

            $('#modalContent').html(`
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary"></div>
                </div>
            `);

            $('#detailsModal').modal('show');

            $.get('@Url.Action("Details", "Circles")/' + id, function (data) {

                $('#modalContent').html(data);

            }).fail(function () {

                $('#modalContent').html(`
                    <div class="alert alert-danger m-3 rounded-3 text-center">
                        حدث خطأ أثناء جلب البيانات.
                    </div>
                `);
            });
        }

    </script>
}

