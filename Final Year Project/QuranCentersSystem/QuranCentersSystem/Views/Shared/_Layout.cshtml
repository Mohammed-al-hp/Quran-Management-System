@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - منظومة إتقان للتحفيظ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        /* تعريف متغيرات الألوان الجديدة (الأخضر والذهبي) */
        :root {
            --primary-green: #1a531a;
            --secondary-green: #2a752a;
            --accent-gold: #c9a050;
            --bg-light: #f4f7f6;
            --text-dark: #2c3e50;
            --sidebar-bg: #1e293b;
        }

        body {
            background-color: var(--bg-light);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-dark);
            direction: rtl;
        }

        /* تنسيقات الهيكل (Layout) */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background-color: var(--sidebar-bg);
            color: white;
            position: fixed;
            right: 0;
            top: 0;
            z-index: 1000;
        }

            .sidebar a {
                color: #bdc3c7;
                text-decoration: none;
                padding: 15px 20px;
                display: block;
                transition: all 0.3s;
                border-bottom: 1px solid #2d3748;
            }

                .sidebar a:hover {
                    background-color: #2d3748;
                    color: white;
                }

            /* كود تمييز الزر النشط في القائمة الجانبية (الأزرق) */
            .sidebar .nav-link.active,
            .sidebar .collapse-item.active {
                background-color: #f8f9fa !important;
                color: #0d6efd !important;
                font-weight: bold;
                border-right: 4px solid #0d6efd;
            }

            .sidebar i {
                margin-left: 10px;
                color: var(--accent-gold);
            }

        .main-content {
            margin-right: 260px;
            padding: 30px;
            background-color: #f4f7f6;
            min-height: 100vh;
            width: calc(100% - 260px);
            flex-grow: 1;
        }

        .top-header {
            background-color: white;
            padding: 15px 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            border-radius: 8px;
            margin-bottom: 30px;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">
            <div class="p-4 text-center border-bottom border-secondary">
                <i class="bi bi-book-half" style="font-size: 3rem; color: var(--accent-gold);"></i>
                <h5 class="mt-3 text-white">منظومة إتقان</h5>
                <small class="text-muted">لتحفيظ القرآن الكريم</small>
            </div>
            <div class="mt-3">
                <a asp-controller="Home" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2"></i> لوحة التحكم
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-controller="Students" asp-action="Index" class="nav-link">
                        <i class="bi bi-people"></i> إدارة الطلاب
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Teachers" asp-action="Index" class="nav-link">
                        <i class="bi bi-person-workspace"></i> إدارة المحفظين
                    </a>

                    <a asp-controller="Circles" asp-action="Index" class="nav-link">
                        <i class="bi bi-mortarboard"></i> إدارة الحلقات
                    </a>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-controller="Attendances" asp-action="GroupAttendance" class="nav-link">
                        <i class="bi bi-calendar-check"></i> الحضور والغياب
                    </a>

                    <li class="nav-item">
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#memorizationMenu" aria-expanded="false">
                            <i class="bi bi-journal-check ms-2"></i>
                            <span>متابعة الحفظ</span>
                            <i class="bi bi-chevron-down me-auto dropdown-arrow"></i>
                        </a>
                        <div id="memorizationMenu" class="collapse">
                            <div class="bg-white py-2 collapse-inner rounded">
                                <a class="collapse-item nav-link text-dark" asp-controller="Memorizations" asp-action="FollowUp">نظام الأسئلة</a>
                                <a class="collapse-item nav-link text-dark" asp-controller="Memorizations" asp-action="DailyRecord">التتبيع المباشر</a>
                            </div>
                        </div>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Reports" asp-action="Index" class="nav-link">
                        <i class="bi bi-graph-up"></i> التقارير والإحصائيات
                    </a>

                    <a class="nav-link text-white" asp-controller="Parents" asp-action="Index">
                        <i class="bi bi-people-fill me-2"></i> إدارة أولياء الأمور
                    </a>

                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")"
                       asp-controller="Payments" asp-action="Index">
                        <i class="bi bi-cash-stack me-2"></i> الإدارة المالية
                    </a>

                    <a asp-controller="Users" asp-action="Index" class="nav-link">
                        <i class="bi bi-person-lock"></i> إدارة المستخدمين
                    </a>
                }
            </div>
        </nav>

        <main class="main-content">
            <header class="top-header d-flex justify-content-between align-items-center">
                <h4 class="m-0 text-dark">@ViewData["Title"]</h4>

                <div class="d-flex align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <span class="me-3 text-muted">مرحباً، @UserManager.GetUserName(User)</span>
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-box-arrow-right"></i> تسجيل الخروج
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">
                            <i class="bi bi-box-arrow-in-right"></i> تسجيل الدخول
                        </a>
                    }
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var currentUrl = window.location.pathname;
            var navLinks = document.querySelectorAll('.nav-link, .collapse-item');

            navLinks.forEach(function(link) {
                var linkHref = link.getAttribute('href');

                if (linkHref && (currentUrl === linkHref || currentUrl.startsWith(linkHref + "/"))) {
                    link.classList.add('active');

                    // إذا كان الزر داخل القائمة المنسدلة، افتحها تلقائياً
                    var parentCollapse = link.closest('.collapse');
                    if (parentCollapse) {
                        parentCollapse.classList.add('show');
                        var toggler = document.querySelector('[data-bs-target="#' + parentCollapse.id + '"]');
                        if (toggler) {
                            toggler.classList.add('active');
                        }
                    }
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>