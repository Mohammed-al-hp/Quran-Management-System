    <!-- SignalR & SweetAlert2 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var currentUrl = window.location.pathname;
            var navLinks = document.querySelectorAll('.nav-link, .collapse-item');

            navLinks.forEach(function(link) {
                var linkHref = link.getAttribute('href');

                if (linkHref && (currentUrl === linkHref || currentUrl.startsWith(linkHref + "/"))) {
                    link.classList.add('active');

                    var parentCollapse = link.closest('.collapse');
                    if (parentCollapse) {
                        parentCollapse.classList.add('show');
                        var toggler = document.querySelector('[data-bs-target="#' + parentCollapse.id + '"]');
                        if (toggler) {
                            toggler.classList.add('active');
                        }
                    }
                }
            });

            // SignalR Connection
            @if (SignInManager.IsSignedIn(User))
            {
                <text>
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();

                connection.on("ReceiveNotification", function (notification) {
                    console.log("New notification received:", notification);
                    
                    // Show SweetAlert2 toast
                    Swal.fire({
                        title: notification.title,
                        text: notification.message,
                        icon: 'info',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 5000,
                        timerProgressBar: true,
                        didOpen: (toast) => {
                            toast.addEventListener('mouseenter', Swal.stopTimer)
                            toast.addEventListener('mouseleave', Swal.resumeTimer)
                        }
                    });

                    // Update Badge
                    const badge = document.getElementById('notificationBadge');
                    let count = parseInt(badge.innerText) || 0;
                    count++;
                    badge.innerText = count;
                    badge.classList.remove('d-none');

                    // Add to dropdown
                    loadNotifications();
                });

                connection.start().catch(err => console.error("SignalR connection error: ", err.toString()));

                function loadNotifications() {
                    fetch('/Notifications/GetRecent')
                        .then(response => response.json())
                        .then(data => {
                            const container = document.getElementById('notificationItems');
                            if (data.length === 0) {
                                container.innerHTML = '<li class="p-4 text-center text-muted">لا توجد تنبيهات جديدة</li>';
                                document.getElementById('notificationBadge').classList.add('d-none');
                                return;
                            }

                            container.innerHTML = '';
                            let unreadCount = 0;
                            data.forEach(n => {
                                if (!n.isRead) unreadCount++;
                                const item = document.createElement('li');
                                item.className = `p-3 border-bottom ${n.isRead ? '' : 'bg-light'}`;
                                item.style.cursor = 'pointer';
                                item.innerHTML = `
                                    <div class="d-flex align-items-start">
                                        <div class="bg-primary rounded-circle p-2 me-2">
                                            <i class="bi bi-info-circle text-white"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between">
                                                <small class="fw-bold">${n.title}</small>
                                                <small class="text-muted" style="font-size: 0.75rem">${new Date(n.createdAt).toLocaleString('ar-EG')}</small>
                                            </div>
                                            <p class="mb-0 text-sm" style="font-size: 0.85rem">${n.message}</p>
                                        </div>
                                    </div>
                                `;
                                item.onclick = () => markAsRead(n.id);
                                container.appendChild(item);
                            });

                            const badge = document.getElementById('notificationBadge');
                            if (unreadCount > 0) {
                                badge.innerText = unreadCount;
                                badge.classList.remove('d-none');
                            } else {
                                badge.classList.add('d-none');
                            }
                        });
                }

                function markAsRead(id) {
                    fetch(`/Notifications/MarkAsRead/${id}`, { method: 'POST' })
                        .then(() => loadNotifications());
                }

                document.getElementById('markAllRead').onclick = function (e) {
                    e.preventDefault();
                    fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                        .then(() => loadNotifications());
                };

                loadNotifications();
                </text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>