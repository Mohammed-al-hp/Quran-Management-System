@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - منظومة إتقان للتحفيظ</title>

    <!-- إضافة خط Cairo من جوجل -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        const storedTheme = localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const currentTheme = storedTheme || systemTheme;
        document.documentElement.setAttribute('data-bs-theme', currentTheme);
    </script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        /* تنسيقات الهيكل (Layout) المتغيرة */
        .sidebar {
            width: 260px;
            height: 100vh; /* تغيير إلى height بدل min-height لضبط التمرير */
            background-color: var(--sidebar-bg);
            color: white;
            position: fixed;
            right: 0;
            top: 0;
            z-index: 1000;
            transition: background-color 0.3s ease;
            overflow-y: auto; /* إضافة خاصية التمرير العمودي */
            overscroll-behavior: contain; /* أضف هذا السطر هنا */
        }

            /* تخصيص شكل شريط التمرير للقائمة الجانبية ليكون أنيقاً */
            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: transparent;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.2);
                border-radius: 10px;
            }

                .sidebar::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 255, 255, 0.4);
                }

            .sidebar a {
                color: #bdc3c7;
                text-decoration: none;
                padding: 15px 20px;
                display: block;
                transition: all 0.3s;
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }

                .sidebar a:hover {
                    background-color: rgba(255,255,255,0.1);
                    color: white;
                }

            .sidebar i {
                margin-left: 10px;
                color: var(--accent-gold);
            }

        .main-content {
            margin-right: 260px;
            padding: 30px;
            background-color: var(--bg-body);
            min-height: 100vh;
            width: calc(100% - 260px);
            flex-grow: 1;
            transition: background-color 0.3s ease;
        }

        .top-header {
            background-color: var(--bg-card);
            padding: 15px 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            border-radius: 8px;
            margin-bottom: 30px;
            transition: background-color 0.3s ease;
            color: var(--text-main);
        }

        .collapse-inner {
            background-color: var(--bg-card) !important;
        }

        .collapse-item {
            color: var(--text-main) !important;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div id="loading-bar"></div>
    <div class="d-flex">
        <nav class="sidebar">
            <div class="p-4 text-center border-bottom border-secondary">
                <i class="bi bi-book-half" style="font-size: 3rem; color: var(--accent-gold);"></i>
                <h5 class="mt-3 text-white">منظومة إتقان</h5>
                <small class="text-muted">لتحفيظ القرآن الكريم</small>
            </div>
            <div class="mt-3">
                <a asp-controller="Home" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2"></i> لوحة التحكم
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-controller="Students" asp-action="Index" class="nav-link">
                        <i class="bi bi-people"></i> إدارة الطلاب
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Teachers" asp-action="Index" class="nav-link">
                        <i class="bi bi-person-workspace"></i> إدارة المحفظين
                    </a>

                    <a asp-controller="Circles" asp-action="Index" class="nav-link">
                        <i class="bi bi-mortarboard"></i> إدارة الحلقات
                    </a>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-controller="Attendances" asp-action="GroupAttendance" class="nav-link">
                        <i class="bi bi-calendar-check"></i> الحضور والغياب
                    </a>

                    <li class="nav-item list-unstyled">
                        <a class="nav-link" asp-controller="FollowUp" asp-action="Index">
                            <i class="bi bi-journal-check ms-2"></i>
                            <span>متابعة الحفظ والمراجعة</span>
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Reports" asp-action="Index" class="nav-link">
                        <i class="bi bi-graph-up"></i> التقارير والإحصائيات
                    </a>

                    <a class="nav-link" asp-controller="Parents" asp-action="Index">
                        <i class="bi bi-people-fill me-2"></i> إدارة أولياء الأمور
                    </a>

                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")"
                       asp-controller="Payments" asp-action="Index">
                        <i class="bi bi-cash-stack me-2"></i> الإدارة المالية
                    </a>

                    <a asp-controller="Users" asp-action="Index" class="nav-link">
                        <i class="bi bi-person-lock"></i> إدارة المستخدمين
                    </a>
                }
            </div>
        </nav>

        <main class="main-content">
            <header class="top-header d-flex justify-content-between align-items-center shadow-sm">
                <div class="d-flex align-items-center">
                    <button class="btn btn-light d-md-none me-2" id="sidebarToggle">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <h4 class="m-0 fw-bold">@ViewData["Title"]</h4>
                </div>

                <div class="d-flex align-items-center">
                    <button class="btn btn-link text-decoration-none me-2" id="themeToggle" type="button">
                        <i class="bi fs-5" id="themeIcon"></i>
                    </button>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle border-0 bg-transparent" data-bs-toggle="dropdown">
                                <span class="d-none d-md-inline ms-1">@UserManager.GetUserName(User)</span>
                                <i class="bi bi-person-circle fs-5 text-primary"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li><a class="dropdown-item text-end" asp-area="Identity" asp-page="/Account/Manage/Index">الملف الشخصي</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger text-end font-bold">تسجيل الخروج</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // --- 1. التحكم في القائمة الجانبية (الجوال) ---
            // تأكدنا هنا أن الـ ID هو sidebarToggle كما هو موجود في الـ Header لديك
            const mobileToggle = document.getElementById('sidebarToggle');
            const body = document.body;

            if(mobileToggle) {
                mobileToggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    body.classList.toggle('sidebar-open');
                });
            }

            // إغلاق القائمة عند النقر في أي مكان خارجها (لتحسين تجربة الجوال)
            document.addEventListener('click', function(e) {
                if (body.classList.contains('sidebar-open') && !e.target.closest('.sidebar')) {
                    body.classList.remove('sidebar-open');
                }
            });

            // --- 2. محاكاة شريط التحميل الاحترافي ---
            function showLoading() {
                const bar = document.getElementById('loading-bar');
                if(bar) {
                    bar.style.width = '0%';
                    bar.style.display = 'block';
                    setTimeout(() => bar.style.width = '70%', 10);
                }
            }

            function hideLoading() {
                const bar = document.getElementById('loading-bar');
                if(bar) {
                    bar.style.width = '100%';
                    setTimeout(() => {
                        bar.style.display = 'none';
                        bar.style.width = '0%';
                    }, 300);
                }
            }

            // تشغيل التحميل عند الانتقال بين الصفحات
            document.querySelectorAll('a:not([target="_blank"]):not([href^="#"])').forEach(link => {
                link.addEventListener('click', function(e) {
                    // لا تشغل التحميل إذا كان الرابط يفتح قائمة منسدلة
                    if(!this.classList.contains('dropdown-toggle')) {
                        showLoading();
                    }
                });
            });

            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', showLoading);
            });

            // إخفاء التحميل عند اكتمال تحميل الصفحة تماماً
            window.addEventListener('load', hideLoading);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>