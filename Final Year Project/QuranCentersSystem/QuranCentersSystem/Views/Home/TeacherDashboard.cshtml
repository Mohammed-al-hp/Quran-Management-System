@{
    ViewData["Title"] = "لوحة تحكم المحفظ";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-primary">
                <i class="bi bi-person-workspace"></i>
                مرحباً، @ViewBag.TeacherName
            </h2>
            <p class="text-muted">لوحة تحكم المحفظ - نظرة عامة على حلقاتك وطلابك</p>
        </div>
    </div>

    <!-- بطاقات الإحصائيات -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #1D5D5D, #2a7a7a);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-circle-fill fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.CirclesCount</h3>
                    <p class="mb-0 opacity-75">حلقاتي</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #C5A059, #d4b76a);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-people-fill fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.StudentsCount</h3>
                    <p class="mb-0 opacity-75">طلابي</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #28a745, #34ce57);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-check-circle-fill fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.TodayAttendance</h3>
                    <p class="mb-0 opacity-75">حضور اليوم</p>
                </div>
            </div>
        </div>
    </div>

    <!-- الإجراءات السريعة -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <a href="/Attendances/GroupAttendance" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-calendar-check fs-1 text-success mb-2 d-block"></i>
                    <h5 class="text-dark">تسجيل الحضور</h5>
                    <p class="text-muted small">تسجيل حضور جماعي لطلاب الحلقة</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/Memorizations/Create" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-journal-plus fs-1 text-primary mb-2 d-block"></i>
                    <h5 class="text-dark">تسجيل إنجاز</h5>
                    <p class="text-muted small">تسجيل درجة حفظ جديدة للطالب</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/Memorizations/DailyRecord" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-mic-fill fs-1 text-warning mb-2 d-block"></i>
                    <h5 class="text-dark">التتبيع اليومي</h5>
                    <p class="text-muted small">تسجيل تسميع مباشر بدون أسئلة</p>
                </div>
            </a>
        </div>
    </div>

    <!-- آخر سجلات الحفظ -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-clock-history"></i> آخر سجلات الحفظ</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>الطالب</th>
                                    <th>السورة</th>
                                    <th>التقييم</th>
                                    <th>التاريخ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.RecentMemorizations != null)
                                {
                                    foreach (var item in ViewBag.RecentMemorizations)
                                    {
                                        <tr>
                                            <td>@item.Student?.Name</td>
                                            <td>@item.SurahName</td>
                                            <td>
                                                @{
                                                    string badgeClass = item.Grade switch
                                                    {
                                                        "ممتاز" => "bg-success",
                                                        "جيد جداً" => "bg-primary",
                                                        "جيد" => "bg-info",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@item.Grade</span>
                                            </td>
                                            <td>@item.Date.ToString("yyyy/MM/dd")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
