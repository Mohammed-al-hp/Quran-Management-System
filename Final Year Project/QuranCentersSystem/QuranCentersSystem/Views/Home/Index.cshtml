@model QuranCentersSystem.Models.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container-fluid px-4" dir="rtl">
    <div class="pt-3 mb-3">
        <h5 class="fw-normal text-muted m-0">نظرة عامة على المركز</h5>
    </div>

    @* الصف الأول: بطاقات الإحصائيات *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-success border-4 rounded-3 stat-card">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">إجمالي الطلاب</p>
                        <h3 class="fw-bold mb-0 theme-text">@Model.TotalStudents</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-people-fill text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-primary border-4 rounded-3 stat-card">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">إجمالي المحفظين</p>
                        <h2 class="fw-bold mb-0 theme-text">@Model.TotalTeachers</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-person-badge-fill text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-warning border-4 rounded-3 stat-card">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">عدد الحلقات</p>
                        <h2 class="fw-bold mb-0 theme-text">@Model.TotalCircles</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-mortarboard-fill text-warning fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-danger border-4 rounded-3 stat-card">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">حضور اليوم</p>
                        <h2 class="fw-bold mb-0 theme-text">@Model.TodayAttendance</h2>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-calendar-check-fill text-danger fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* الصف الثاني: الإجراءات السريعة *@
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-normal text-muted mb-3">الإجراءات السريعة</h5>
                <div class="d-flex flex-wrap gap-3">
                    @* لاحظ إضافة gap-2 هنا وإزالة الهوامش من الأيقونة *@
                    <a asp-controller="Students" asp-action="Create" class="btn btn-success shadow-sm flex-fill d-flex align-items-center justify-content-center gap-2 py-3">
                        <i class="bi bi-person-plus fs-4"></i>
                        <span class="fw-bold">إضافة طالب جديد</span>
                    </a>

                    <a asp-controller="Circles" asp-action="Create" class="btn btn-warning shadow-sm flex-fill d-flex align-items-center justify-content-center gap-2 py-3 text-dark">
                        <i class="bi bi-journal-plus fs-4"></i>
                        <span class="fw-bold">تسجيل حلقة جديدة</span>
                    </a>

                    <a asp-controller="Memorizations" asp-action="Create" class="btn btn-primary shadow-sm flex-fill d-flex align-items-center justify-content-center gap-2 py-3">
                        <i class="bi bi-calendar-check fs-4"></i>
                        <span class="fw-bold">تسجيل حضور جديد</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* الصف الثالث: الرسم البياني *@
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4 text-center">
                <h5 class="text-muted mb-3">تحليل المستويات الحقيقي</h5>
                <div style="height: 300px;">
                    <canvas id="levelsChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* يمكنك إضافة التنسيقات الإضافية الخاصة بك هنا إن وجدت */
    .stat-card {
        transition: transform 0.2s ease-in-out;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const ctx = document.getElementById('levelsChart').getContext('2d');

            const levelsChart = new Chart(ctx, {
                type: 'polarArea',
                data: {
                    labels: ['ممتاز', 'جيد جداً', 'جيد', 'مقبول'],
                    datasets: [{
                        data: [@Model.ExcellentCount, @Model.VeryGoodCount, @Model.GoodCount, @Model.FairCount],
                        backgroundColor: [
                            'rgba(26, 83, 26, 0.7)',
                            'rgba(42, 117, 42, 0.7)',
                            'rgba(201, 160, 80, 0.7)',
                            'rgba(220, 53, 69, 0.7)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        });
    </script>
}