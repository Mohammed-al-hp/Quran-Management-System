@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">لوحة التحكم</h2>
    </div>

    <h5 class="text-muted mb-4">نظرة عامة على المركز</h5>

    @* الصف الأول: بطاقات الإحصائيات الأربعة *@
    <div class="row mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-bottom border-danger border-4 rounded-3 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-calendar-check text-danger fs-2"></i>
                    </div>
                    <div class="text-end">
                        <p class="text-muted mb-1">حضور اليوم</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TodayAttendance</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-bottom border-warning border-4 rounded-3 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-mortarboard text-warning fs-2"></i>
                    </div>
                    <div class="text-end">
                        <p class="text-muted mb-1">عدد الحلقات</p>
                        <h3 class="fw-bold mb-0">@ViewBag.CirclesCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-bottom border-primary border-4 rounded-3 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-person-video3 text-primary fs-2"></i>
                    </div>
                    <div class="text-end">
                        <p class="text-muted mb-1">إجمالي المحفظين</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TeachersCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-bottom border-success border-4 rounded-3 h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-people text-success fs-2"></i>
                    </div>
                    <div class="text-end">
                        <p class="text-muted mb-1">إجمالي الطلاب</p>
                        <h3 class="fw-bold mb-0">@ViewBag.StudentsCount</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* إجراءات سريعة *@
    <h5 class="text-muted mb-3">إجراءات سريعة</h5>
    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 mb-2 bg-white rounded">
                <div class="d-flex align-items-center justify-content-between">
                    <h6 class="mb-0 fw-bold">تسجيل طالب جديد</h6>
                    <i class="bi bi-person-plus text-success fs-4"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 mb-2 bg-white rounded border-primary">
                <div class="d-flex align-items-center justify-content-between">
                    <h6 class="mb-0 fw-bold">تسجيل حضور حلقة</h6>
                    <i class="bi bi-check2-circle text-primary fs-4"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 mb-2 bg-white rounded">
                <div class="d-flex align-items-center justify-content-between">
                    <h6 class="mb-0 fw-bold">إضافة ورد حفظ</h6>
                    <i class="bi bi-journal-plus text-warning fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    @* تحليل المستويات *@
    <h5 class="text-muted mb-3">تحليل مستويات الطلاب (التقييمات)</h5>
    <div class="card border-0 shadow-sm p-4">
        <div style="height: 300px;">
            <canvas id="gradesChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('gradesChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['ممتاز', 'جيد جداً', 'جيد', 'مقبول'],
                datasets: [{
                    label: 'عدد الطلاب',
                    data: [@ViewBag.ExcellentCount, @ViewBag.VeryGoodCount, @ViewBag.GoodCount, @ViewBag.FairCount],
                    backgroundColor: '#28a745' // نفس اللون الأخضر في صورتك
                }]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
}