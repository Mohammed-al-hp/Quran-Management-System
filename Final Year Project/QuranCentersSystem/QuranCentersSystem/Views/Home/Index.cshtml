@{
    ViewData["Title"] = "الرئيسية";
}

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">لوحة التحكم</h2>
    </div>

    <h5 class="text-muted mb-4">نظرة عامة على المركز</h5>

    @* بطاقات الإحصائيات *@
    <div class="row mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-bottom border-danger border-4 rounded-3 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-3">
                        <i class="bi bi-calendar-check text-danger fs-2"></i>
                    </div>
                    <div class="text-end">
                        <p class="text-muted mb-1">حضور اليوم</p>
                        <h3 class="fw-bold mb-0">@(ViewBag.TodayAttendance ?? 0)</h3>
                    </div>
                </div>
            </div>
        </div>
        @* كرر باقي البطاقات الأربعة هنا بنفس النمط *@
    </div>

    <h5 class="mb-4 text-muted">إجراءات سريعة</h5>
    <div class="row mb-5">
        <div class="col-md-4 mb-3">
            <a asp-controller="Students" asp-action="Create" class="card shadow-sm bg-white h-100 text-decoration-none text-dark border-0 border-start border-success border-4 action-card">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-person-plus text-success me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">إضافة طالب جديد</span>
                </div>
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a asp-controller="Attendances" asp-action="GroupAttendance" class="card shadow-sm bg-white h-100 text-decoration-none text-dark border-0 border-start border-primary border-4 action-card">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-check-circle text-primary me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">تسجيل حضور جماعي</span>
                </div>
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a asp-controller="Memorizations" asp-action="Create" class="card shadow-sm bg-white h-100 text-decoration-none text-dark border-0 border-start border-warning border-4 action-card">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-file-earmark-plus text-warning me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">إضافة سجل حفظ</span>
                </div>
            </a>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card shadow-sm bg-white rounded p-4 border-0">
                <h5 class="card-title text-muted mb-4">تحليل مستويات الطلاب (التقييمات)</h5>
                <div style="height: 350px;">
                    <canvas id="gradesChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('gradesChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['ممتاز', 'جيد جداً', 'جيد', 'مقبول'],
                datasets: [{
                    label: 'عدد الطلاب',
                    data: [@(ViewBag.ExcellentCount ?? 0), @(ViewBag.VeryGoodCount ?? 0), @(ViewBag.GoodCount ?? 0), @(ViewBag.FairCount ?? 0)],
                    backgroundColor: '#28a745'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
}