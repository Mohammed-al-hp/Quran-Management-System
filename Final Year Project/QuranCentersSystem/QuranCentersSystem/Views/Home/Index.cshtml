@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container-fluid px-4" dir="rtl">
    @* التعديل: جعل الخط باهتاً وإضافة مسافة سفلية mb-3 لإبعاده عن البطاقات *@
    <div class="pt-3 mb-3">
        <h5 class="fw-normal text-muted m-0">نظرة عامة على المركز</h5>
    </div>

    @* الصف الأول: بطاقات الإحصائيات *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-success border-4 rounded-3 stat-card bg-white">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">إجمالي الطلاب</p>
                        <h3 class="fw-bold mb-0 text-dark">@ViewBag.StudentsCount</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-people-fill text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-primary border-4 rounded-3 stat-card bg-white">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">إجمالي المحفظين</p>
                        <h2 class="fw-bold mb-0 text-dark">@ViewBag.TeachersCount</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-person-badge-fill text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-warning border-4 rounded-3 stat-card bg-white">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">عدد الحلقات</p>
                        <h2 class="fw-bold mb-0 text-dark">@ViewBag.CirclesCount</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-mortarboard-fill text-warning fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 shadow-sm border-0 border-start border-danger border-4 rounded-3 stat-card bg-white">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div>
                        <p class="text-muted small fw-bold mb-1">حضور اليوم</p>
                        <h2 class="fw-bold mb-0 text-dark">@ViewBag.TodayAttendance</h2>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-calendar-check-fill text-danger fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* إجراءات سريعة *@
    <h6 class="text-muted fw-normal mb-3">إجراءات سريعة</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <a asp-controller="Students" asp-action="Create" class="text-decoration-none shadow-hover">
                <div class="card border-0 shadow-sm p-3 h-100 action-card bg-white">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-plus text-success fs-5 me-3"></i>
                            <h6 class="mb-0 fw-bold text-dark">تسجيل طالب جديد</h6>
                        </div>
                        <i class="bi bi-chevron-left text-muted small"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Attendances" asp-action="GroupAttendance" class="text-decoration-none shadow-hover">
                <div class="card border-0 shadow-sm p-3 h-100 action-card bg-white">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check2-circle text-primary fs-5 me-3"></i>
                            <h6 class="mb-0 fw-bold text-dark">تسجيل حضور حلقة</h6>
                        </div>
                        <i class="bi bi-chevron-left text-muted small"></i>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Memorizations" asp-action="Create" class="text-decoration-none shadow-hover">
                <div class="card border-0 shadow-sm p-3 h-100 action-card bg-white">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-journal-plus text-warning fs-5 me-3"></i>
                            <h6 class="mb-0 fw-bold text-dark">إضافة ورد حفظ</h6>
                        </div>
                        <i class="bi bi-chevron-left text-muted small"></i>
                    </div>
                </div>
            </a>
        </div>
    </div>

    @* تحليل المستويات *@
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4 mb-4 bg-white">
                <h6 class="text-muted fw-bold mb-4">تحليل مستويات الطلاب (التقييمات)</h6>
                <div style="height: 300px;">
                    <canvas id="gradesChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* تقليل المسافة العلوية للصفحة لرفع المحتوى لأقصى حد */
    .container-fluid {
        margin-top: -15px !important;
    }

    .stat-card {
        transition: transform 0.2s ease;
        min-height: 100px;
    }

        .stat-card:hover {
            transform: translateY(-3px);
        }

    .action-card {
        transition: all 0.3s ease;
    }

        .action-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
            background-color: #fcfcfc !important;
        }
</style>