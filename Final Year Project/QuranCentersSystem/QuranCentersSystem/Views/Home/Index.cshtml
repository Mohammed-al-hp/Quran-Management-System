@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container-fluid" dir="rtl">
    <h5 class="mb-4 text-muted">نظرة عامة على المركز</h5>

    <div class="row mb-5">
        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-success border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-people text-success" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">إجمالي الطلاب</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.Students</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-primary border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-person-badge text-primary" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">إجمالي المحفظين</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.Teachers</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-warning border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-mortarboard text-warning" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">عدد الحلقات</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.Circles</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-danger border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-calendar-check text-danger" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">حضور اليوم</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.AttendanceToday</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mb-4 text-muted">إجراءات سريعة</h5>
    <div class="row">
        <div class="col-md-4 mb-3">
            <a asp-controller="Students" asp-action="Create" class="card shadow-sm bg-white h-100 text-decoration-none text-dark card-stats">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-person-plus text-success me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">تسجيل طالب جديد</span>
                </div>
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a href="#" class="card shadow-sm bg-white h-100 text-decoration-none text-dark card-stats">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-check-circle text-primary me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">تسجيل حضور حلقة</span>
                </div>
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a asp-controller="Memorizations" asp-action="Create" class="card shadow-sm bg-white h-100 text-decoration-none text-dark card-stats">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-file-earmark-plus text-gold me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">إضافة ورد حفظ</span>
                </div>
            </a>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card shadow-sm bg-white rounded p-4">
                <h5 class="card-title text-muted mb-4">توزيع الطلاب حسب المستويات</h5>
                <div class="text-center p-5 bg-light rounded" style="border: 2px dashed #cbd5e1;">
                    <i class="bi bi-pie-chart text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-2">سيتم عرض مخطط بياني هنا (مثلاً: جزء عم، جزء تبارك...)</p>
                </div>
            </div>
        </div>
    </div>

</div>