@{
    ViewData["Title"] = "الرئيسية";
}

<div class="container-fluid" dir="rtl">
    <h5 class="mb-4 text-muted">مرحباً بك في لوحة التحكم</h5>

    @* إحصائيات عامة *@
    <div class="row mb-5">
        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-success border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-people text-success" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">إجمالي الطلاب</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.StudentsCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-primary border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-person-badge text-primary" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">إجمالي المحفظين</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.TeachersCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-warning border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-mortarboard text-warning" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">عدد الحلقات</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.CirclesCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-stats shadow-sm bg-white border-start border-danger border-4">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-calendar-check text-danger" style="font-size: 2rem;"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">حضور اليوم</h6>
                        <h2 class="card-title mb-0 fw-bold">@ViewBag.TodayAttendance</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mb-4 text-muted">إجراءات سريعة</h5>
    <div class="row">
        <div class="col-md-4 mb-3">
            <a asp-controller="Students" asp-action="Create" class="card shadow-sm bg-white h-100 text-decoration-none text-dark border-0 action-card">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-person-plus text-success me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">إضافة طالب جديد</span>
                </div>
            </a>
        </div>

        @* ?? ??????? ???: ?? ????? ?????? ??? GroupAttendance ?????? ??????? *@
        <div class="col-md-4 mb-3">
            <a asp-controller="Attendances" asp-action="GroupAttendance" class="card shadow-sm bg-white h-100 text-decoration-none text-dark border-0 action-card">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-check-circle text-primary me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">تسجيل حضور جماعي</span>
                </div>
            </a>
        </div>

        <div class="col-md-4 mb-3">
            <a asp-controller="Memorizations" asp-action="Create" class="card shadow-sm bg-white h-100 text-decoration-none text-dark border-0 action-card">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-file-earmark-plus text-warning me-3" style="font-size: 1.5rem;"></i>
                    <span class="fw-bold">إضافة سجل حفظ</span>
                </div>
            </a>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-12">
            <div class="card shadow-sm bg-white rounded p-4 border-0">
                <h5 class="card-title text-muted mb-4">توزيع تقييمات الطلاب (الدرجات)</h5>
                <div style="height: 350px;">
                    <canvas id="gradesChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .action-card {
        transition: all 0.3s ease;
    }

        .action-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            background-color: #f8f9fa !important;
        }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var ctx = document.getElementById('gradesChart').getContext('2d');
        var gradesChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['ممتاز', 'جيد جداً', 'جيد', 'مقبول'],
                datasets: [{
                    label: 'إحصائيات التقييمات',
                    data: [@ViewBag.ExcellentCount, @ViewBag.VeryGoodCount, @ViewBag.GoodCount, @ViewBag.FairCount],
                    backgroundColor: [
                        'rgba(40, 167, 69, 0.7)',
                        'rgba(13, 110, 253, 0.7)',
                        'rgba(255, 193, 7, 0.7)',
                        'rgba(220, 53, 69, 0.7)'
                    ],
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });
    </script>
}