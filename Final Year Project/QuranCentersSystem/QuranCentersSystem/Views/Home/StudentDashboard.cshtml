@{
    ViewData["Title"] = "لوحة تحكم الطالب";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-primary">
                <i class="bi bi-book"></i>
                مرحباً، @ViewBag.StudentName
            </h2>
            <p class="text-muted">لوحة الطالب - تابع تقدمك في حفظ القرآن الكريم</p>
            <span class="badge bg-primary fs-6 px-3 py-2">
                <i class="bi bi-circle-fill"></i> الحلقة: @ViewBag.CircleName
            </span>
        </div>
    </div>

    <!-- بطاقات الإحصائيات -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #28a745, #34ce57);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-check-circle-fill fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.PresentCount</h3>
                    <p class="mb-0 opacity-75">أيام الحضور</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #dc3545, #e4606d);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-x-circle-fill fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.AbsentCount</h3>
                    <p class="mb-0 opacity-75">أيام الغياب</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #1D5D5D, #2a7a7a);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-calendar3 fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.TotalAttendance</h3>
                    <p class="mb-0 opacity-75">إجمالي الأيام</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #C5A059, #d4b76a);">
                <div class="card-body text-white text-center py-4">
                    <i class="bi bi-star-fill fs-1 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-1">@ViewBag.AverageGrade</h3>
                    <p class="mb-0 opacity-75">متوسط التقييم</p>
                </div>
            </div>
        </div>
    </div>

    <!-- آخر الدرجات -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-journal-text"></i> آخر سجلات الحفظ والتقييم</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>السورة</th>
                                    <th>النوع</th>
                                    <th>من آية</th>
                                    <th>إلى آية</th>
                                    <th>التقييم</th>
                                    <th>الأخطاء</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.RecentGrades != null)
                                {
                                    foreach (var item in ViewBag.RecentGrades)
                                    {
                                        <tr>
                                            <td>@item.Date.ToString("yyyy/MM/dd")</td>
                                            <td>@item.SurahName</td>
                                            <td>@item.Type</td>
                                            <td>@item.FromAyah</td>
                                            <td>@item.ToAyah</td>
                                            <td>
                                                @{
                                                    string badgeClass = item.Grade switch
                                                    {
                                                        "ممتاز" => "bg-success",
                                                        "جيد جداً" => "bg-primary",
                                                        "جيد" => "bg-info",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@item.Grade</span>
                                            </td>
                                            <td>@item.MistakesCount</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
