@{
    ViewData["Title"] = "لوحة تحكم الطالب";
}

<style>
    /* Micro-animations and Premium Aesthetic */
    .dashboard-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
    }
    .dashboard-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .badge-icon {
        width: 64px;
        height: 64px;
        object-fit: contain;
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.15));
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .badge-wrapper:hover .badge-icon {
        transform: scale(1.15) rotate(5deg);
    }
    .premium-gradient-gold {
        background: linear-gradient(135deg, #F3B33E, #D48C17);
        color: white;
    }
    .premium-gradient-primary {
        background: linear-gradient(135deg, #1D5D5D, #124040);
        color: white;
    }
    .premium-gradient-success {
        background: linear-gradient(135deg, #2B8A5A, #1A5E3A);
        color: white;
    }
    .gamification-points {
        font-size: 3.5rem;
        font-weight: 800;
        text-shadow: 0 2px 4px rgba(0,0,0,0.2);
    }
    /* Empty State Badges */
    .empty-badges {
        opacity: 0.5;
        border: 2px dashed #ccc;
        border-radius: 12px;
        padding: 2rem;
    }
</style>

<div class="container-fluid py-4" dir="rtl">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-person-circle me-2"></i>
                مرحباً، @ViewBag.StudentName
            </h2>
            <p class="text-muted mb-0">لوحة الطالب - تابع تقدمك وإنجازاتك في التلاوة والحفظ</p>
        </div>
        <div class="col-md-4 text-end mt-3 mt-md-0">
            <span class="badge bg-primary bg-opacity-10 text-primary fs-6 px-4 py-2 border border-primary rounded-pill">
                <i class="bi bi-diagram-3-fill"></i> الحلقة: @ViewBag.CircleName
            </span>
        </div>
    </div>

    <!-- بطاقات الإحصائيات مع نقاط الجيمنفيكيشن -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card dashboard-card premium-gradient-gold border-0 shadow-sm h-100">
                <div class="card-body text-center py-4 d-flex flex-column justify-content-center">
                    <h5 class="opacity-75 mb-0 fw-bold">النقاط المكتسبة</h5>
                    <div class="gamification-points my-2">@ViewBag.TotalPoints</div>
                    <p class="mb-0 fs-6"><i class="bi bi-stars"></i> واصل الحفظ لزيادة نقاطك!</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card dashboard-card premium-gradient-primary border-0 shadow-sm h-100">
                <div class="card-body text-center py-4 d-flex flex-column justify-content-center">
                    <i class="bi bi-star-fill fs-1 mb-2"></i>
                    <h2 class="fw-bold mb-1">@ViewBag.AverageGrade</h2>
                    <p class="mb-0 opacity-75 fs-7">متوسط التقييم</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card premium-gradient-success border-0 shadow-sm h-100">
                <div class="card-body text-center py-4 d-flex flex-column justify-content-center">
                    <i class="bi bi-check-circle-fill fs-1 mb-2"></i>
                    <h2 class="fw-bold mb-1">@ViewBag.PresentCount <small class="fs-5 opacity-75">/ @ViewBag.TotalAttendance</small></h2>
                    <p class="mb-0 opacity-75 fs-7">مرات الحضور</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dashboard-card bg-danger bg-gradient text-white border-0 shadow-sm h-100">
                <div class="card-body text-center py-4 d-flex flex-column justify-content-center">
                    <i class="bi bi-x-octagon-fill fs-1 mb-2"></i>
                    <h2 class="fw-bold mb-1">@ViewBag.AbsentCount</h2>
                    <p class="mb-0 opacity-75 fs-7">مرات الغياب</p>
                </div>
            </div>
        </div>
    </div>

    <!-- قسم الأوسمة والجوائز -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-award fs-3 text-warning me-2"></i>
                <h4 class="fw-bold mb-0">لوحة الشرف والأوسمة</h4>
            </div>
            
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 text-center">
                    @if (ViewBag.StudentBadges != null && ((IEnumerable<dynamic>)ViewBag.StudentBadges).Any())
                    {
                        <div class="row justify-content-center g-4">
                            @foreach (var badge in ViewBag.StudentBadges)
                            {
                                <div class="col-md-2 col-6 badge-wrapper">
                                    @{ string defaultIcon = badge.BadgeName.Contains("مبتدئ") ? "bronze" : badge.BadgeName.Contains("مثابر") ? "silver" : badge.BadgeName.Contains("متميز") ? "gold" : "diamond"; }
                                    <!-- Use a default icon logic if iconUrl is not pointing correctly -->
                                    <div class="badge-icon-bg bg-light rounded-circle shadow-sm mx-auto p-3 mb-2 d-inline-flex" style="width:90px; height:90px;">
                                        <i class="bi bi-shield-check text-warning" style="font-size:3rem; line-height: 1;"></i>
                                    </div>
                                    <h6 class="fw-bold text-dark mt-2 mb-1">@badge.BadgeName</h6>
                                    <small class="text-muted d-block" style="font-size:0.75rem;">@badge.DateEarned.ToString("yyyy/MM/dd")</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-badges">
                            <i class="bi bi-lock fs-1 text-muted mb-3 d-block"></i>
                            <h5 class="text-muted fw-bold">لم تكتسب أي أوسمة بعد</h5>
                            <p class="text-muted mb-0">اجتهد واحصل على 50 نقطة كبداية لفتح الأوسمة الأولى!</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- سجل التسميع الأخير -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-4 d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold mb-0"><i class="bi bi-journal-text text-primary me-2"></i>سجل الحفظ الأخير</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3 px-4 rounded-end">التاريخ</th>
                                <th class="py-3">السورة</th>
                                <th class="py-3">المقطع</th>
                                <th class="py-3">النوع</th>
                                <th class="py-3 text-center">التقييم</th>
                                <th class="py-3 text-center rounded-start">الأخطاء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentGrades != null && ((IEnumerable<dynamic>)ViewBag.RecentGrades).Any())
                            {
                                foreach (var item in ViewBag.RecentGrades)
                                {
                                    <tr>
                                        <td class="px-4 text-muted fw-medium py-3">@item.Date.ToString("yyyy/MM/dd")</td>
                                        <td class="fw-bold text-dark">سورة @item.SurahName</td>
                                        <td><span class="text-muted">آية @item.FromAyah إلى @item.ToAyah</span></td>
                                        <td>
                                            <span class="badge bg-light text-dark border">@item.Type</span>
                                        </td>
                                        <td class="text-center">
                                            @{
                                                string badgeClass = item.Grade switch
                                                {
                                                    "ممتاز" => "bg-success text-white shadow-sm",
                                                    "جيد جداً" => "bg-primary text-white shadow-sm",
                                                    "جيد" => "bg-info text-dark",
                                                    _ => "bg-secondary text-white"
                                                };
                                            }
                                            <span class="badge rounded-pill px-3 py-2 @badgeClass" style="font-size: 0.8rem;">@item.Grade</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-circle p-2">@item.MistakesCount</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">لم يتم العثور على سجلات للحفظ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
