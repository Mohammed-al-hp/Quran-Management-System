@model IEnumerable<QuranCenters.Core.Entities.Notification>

@{
    ViewData["Title"] = "التنبيهات والرسائل";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="card shadow-sm border-0 bg-white rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="m-0 text-success fw-bold">مركز الإشعارات</h4>
                <p class="text-muted small mb-0">تابع آخر التحديثات، التقييمات، وتنبيهات الحضور</p>
            </div>
            <button class="btn btn-outline-primary btn-sm rounded-pill px-3" id="markAllReadPage">
                <i class="bi bi-check2-all me-1"></i> تحديد الكل كمقروء
            </button>
        </div>

        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @if (!Model.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <i class="bi bi-bell-slash display-1 opacity-25"></i>
                        <p class="mt-3 fs-5">لا توجد تنبيهات حالياً</p>
                    </div>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <div class="list-group-item list-group-item-action p-4 border-0 @(item.IsRead ? "" : "bg-light border-start border-4 border-success")" 
                             onclick="markReadAndDetail(@item.Id)" style="cursor: pointer;">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 me-3">
                                        @switch (item.Type)
                                        {
                                            case "Attendance": <i class="bi bi-calendar-check fs-4"></i>; break;
                                            case "Grade": <i class="bi bi-star fs-4"></i>; break;
                                            case "Badge": <i class="bi bi-trophy fs-4"></i>; break;
                                            default: <i class="bi bi-info-circle fs-4"></i>; break;
                                        }
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-dark fs-5">@item.Title</h6>
                                        <p class="mb-1 text-secondary">@item.Message</p>
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("g")
                                        </small>
                                    </div>
                                </div>
                                @if (!item.IsRead)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">جديد</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('markAllReadPage').onclick = function() {
            fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                .then(() => location.reload());
        };

        function markReadAndDetail(id) {
            fetch('/Notifications/MarkAsRead/' + id, { method: 'POST' })
                .then(() => {
                    // Refresh or navigate if there's a related link
                    location.reload();
                });
        }
    </script>
}
