@model IEnumerable<QuranCentersSystem.Models.Student>

<div class="container-fluid py-4" dir="rtl">
    <div class="card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="text-success fw-bold">قائمة الطلاب</h4>
            <a asp-action="Create" class="btn btn-success">إضافة طالب</a>
        </div>

        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>الاسم</th>
                    <th>الحلقة</th>
                    <th>الحالة</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@(item.Circle?.Name ?? "غير محدد")</td>
                        <td><span class="badge @(item.Status == "نشط" ? "bg-success" : "bg-secondary")">@item.Status</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                @* زر التعديل المتاح للجميع *@
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-circle">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @* 🔴 تعديل الشرط لضمان ظهور زر الحذف لحسابك الحالي 🔴 *@
                                @if (User.Identity.Name == "admin@example.com" || User.IsInRole("Admin") || User.IsInRole("مدير النظام"))
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا الطالب؟')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>