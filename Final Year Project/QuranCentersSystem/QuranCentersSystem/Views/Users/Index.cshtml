@model IEnumerable<QuranCentersSystem.Models.ApplicationUser>

<div class="container-fluid py-4" dir="rtl">
    <div class="card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="text-primary fw-bold">إدارة مستخدمي النظام</h4>
            @* زر إضافة مستخدم جديد (تأكد من وجود دالة Create في UsersController) *@
            <a asp-action="Create" class="btn btn-primary">إضافة مستخدم</a>
        </div>

        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>اسم المستخدم</th>
                    <th>البريد الإلكتروني</th>
                    <th>رقم الهاتف</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        @* تم تغيير الخصائص هنا لتناسب ApplicationUser *@
                        <td>@item.UserName</td>
                        <td>@item.Email</td>
                        <td>@item.PhoneNumber</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-circle">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                @* شرط الحذف للمدراء فقط *@
                                @if (User.IsInRole("Admin") || User.IsInRole("مدير النظام"))
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا المستخدم؟')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>