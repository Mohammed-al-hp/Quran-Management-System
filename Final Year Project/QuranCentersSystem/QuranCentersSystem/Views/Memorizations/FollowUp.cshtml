@model QuranCentersSystem.Models.Memorization

@{
    ViewData["Title"] = "جلسة المتابعة والأسئلة";
}

<div class="container-fluid py-4" dir="rtl">

    <div class="mb-4">
        <h3 class="text-dark mb-1 fw-bold">جلسة المتابعة والتقييم</h3>
        <p class="text-muted mb-0">سؤال الطالب وتدوين تقييم الحفظ الأسبوعي</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                <div class="card-body p-4">

                    <form asp-action="FollowUp" method="post">

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-secondary fw-bold">تاريخ المتابعة</label>
                                <input asp-for="Date" type="date" class="form-control" style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary fw-bold">اليوم</label>
                                <select asp-for="DayName" class="form-select" style="border-radius: 8px;">
                                    <option value="السبت">السبت</option>
                                    <option value="الأحد">الأحد</option>
                                    <option value="الإثنين">الإثنين</option>
                                    <option value="الثلاثاء">الثلاثاء</option>
                                    <option value="الأربعاء">الأربعاء</option>
                                    <option value="الخميس">الخميس</option>
                                </select>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label text-secondary fw-bold">اسم الطالب</label>
                                <select asp-for="StudentId" class="form-select" style="border-radius: 8px;" asp-items="@(new SelectList(ViewBag.Students, "Id", "Name"))">
                                    <option value="">-- اختر الطالب --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary fw-bold">السورة الحالية</label>
                                <input asp-for="CurrentSurah" class="form-control" placeholder="مثلاً: البقرة" style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary fw-bold">المقدار (من - إلى)</label>
                                <input asp-for="Scope" class="form-control" placeholder="مثلاً: من 1 إلى 50" style="border-radius: 8px;" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label text-secondary fw-bold mb-0">الأسئلة والتقييم التفصيلي</label>
                                <button type="button" class="btn btn-outline-success btn-sm px-3" style="border-radius: 8px;" onclick="addQuestionField()">
                                    <i class="bi bi-plus-lg"></i> إضافة سؤال آخر
                                </button>
                            </div>

                            <div id="questionsContainer">
                                <div class="question-row bg-light p-3 mb-2" style="border-radius: 10px;">
                                    <div class="row g-2">
                                        <div class="col-md-7">
                                            <input type="text" name="Questions" class="form-control" placeholder="اكتب نص السؤال أو موضع الآية..." style="border-radius: 8px;" />
                                        </div>
                                        <div class="col-md-5">
                                            <input type="text" name="Answers" class="form-control" placeholder="درجة الإجابة أو الملاحظة..." style="border-radius: 8px;" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-12">
                                <label class="form-label text-secondary fw-bold">التقييم العام للحلقة</label>
                                <div class="d-flex gap-2">
                                    <input type="radio" class="btn-check" name="Grade" id="g1" value="ممتاز" checked>
                                    <label class="btn btn-outline-success rounded-pill px-4" for="g1">ممتاز</label>

                                    <input type="radio" class="btn-check" name="Grade" id="g2" value="جيد جداً">
                                    <label class="btn btn-outline-primary rounded-pill px-4" for="g2">جيد جداً</label>

                                    <input type="radio" class="btn-check" name="Grade" id="g3" value="جيد">
                                    <label class="btn btn-outline-warning rounded-pill px-4" for="g3">جيد</label>

                                    <input type="radio" class="btn-check" name="Grade" id="g4" value="يحتاج لمراجعة">
                                    <label class="btn btn-outline-danger rounded-pill px-4" for="g4">يحتاج لمراجعة</label>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label text-secondary fw-bold">ملاحظات عامة</label>
                                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="أي ملاحظات أخرى حول أداء الطالب..." style="border-radius: 8px;"></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-dark px-5 py-2" style="border-radius: 10px;">
                                <i class="bi bi-save2-fill ms-1"></i> حفظ التقييم
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function addQuestionField() {
        var container = document.getElementById("questionsContainer");
        var div = document.createElement("div");
        div.className = "question-row bg-light p-3 mb-2";
        div.style.borderRadius = "10px";
        div.innerHTML = `
            <div class="row g-2">
                <div class="col-md-7">
                    <input type="text" name="Questions" class="form-control" placeholder="اكتب نص السؤال أو موضع الآية..." style="border-radius: 8px;" />
                </div>
                <div class="col-md-5">
                    <input type="text" name="Answers" class="form-control" placeholder="درجة الإجابة أو الملاحظة..." style="border-radius: 8px;" />
                </div>
            </div>
        `;
        container.appendChild(div);
    }
</script>