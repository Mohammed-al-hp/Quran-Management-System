@model QuranCenters.Core.Entities.Student

@{
    ViewData["Title"] = "تفاصيل الطالب";
    var thisWeek = ViewBag.ThisWeekPages ?? 0;
    var lastWeek = ViewBag.LastWeekPages ?? 0;
}

<div class="container-fluid py-4" dir="rtl">
    <div class="row g-4">
        <!-- Main Info Card -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 bg-white p-4 rounded-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <div>
                        <h4 class="m-0 text-success fw-bold">ملف الطالب: @Model.Name</h4>
                        <p class="text-muted small mb-0">عرض وتحليل مسيرة الحفظ والتقدم التعليمي</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-3 rounded-pill shadow-sm">
                            <i class="bi bi-pencil me-1"></i> تعديل
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-3 rounded-pill shadow-sm">
                            <i class="bi bi-arrow-right me-1"></i> العودة
                        </a>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="p-3 border rounded-4 bg-light">
                            <h6 class="fw-bold text-secondary mb-3 border-bottom pb-2">المعلومات الشخصية</h6>
                            <dl class="row mb-0">
                                <dt class="col-sm-5 text-muted">الاسم الكامل:</dt>
                                <dd class="col-sm-7 fw-bold">@Model.Name</dd>

                                <dt class="col-sm-5 text-muted">تاريخ الانضمام:</dt>
                                <dd class="col-sm-7">@Model.JoinDate.ToShortDateString()</dd>

                                <dt class="col-sm-5 text-muted">اسم الحلقة:</dt>
                                <dd class="col-sm-7 text-primary fw-bold">@Model.Circle?.Name</dd>

                                <dt class="col-sm-5 text-muted">الحالة:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge @(Model.Status == "نشط" ? "bg-success" : "bg-secondary") rounded-pill px-3">
                                        @(Model.Status ?? "غير محدد")
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-4 border border-primary border-opacity-25 rounded-4 bg-primary bg-opacity-10 h-100 d-flex flex-column justify-content-center align-items-center text-center">
                            <h6 class="text-primary fw-bold mb-3">إجمالي الأوسمة والنقاط</h6>
                            <div class="d-flex gap-3">
                                <div class="text-center">
                                    <div class="h3 fw-bold text-warning mb-0">@Model.PointsLedgers?.Sum(p => p.Points)</div>
                                    <small class="text-muted">نقطة</small>
                                </div>
                                <div class="vr"></div>
                                <div class="text-center">
                                    <div class="h3 fw-bold text-info mb-0">@Model.StudentBadges?.Count</div>
                                    <small class="text-muted">أوسمة</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Progress Analytics Chart Container -->
                <div class="mt-2 text-center">
                     <h5 class="fw-bold text-dark mb-4"><i class="bi bi-bar-chart-line-fill text-primary me-2"></i>تحليل الأداء الأسبوعي (عدد الصفحات)</h5>
                     <div style="height: 300px;">
                         <canvas id="progressChart"></canvas>
                     </div>
                     <div class="mt-3 p-3 bg-light rounded-3 d-flex justify-content-around">
                         <div class="text-center">
                             <small class="text-muted d-block">هذا الأسبوع</small>
                             <span class="badge bg-success fs-6 px-3">@thisWeek صفحة</span>
                         </div>
                         <div class="text-center">
                             <small class="text-muted d-block">الأسبوع الماضي</small>
                             <span class="badge bg-primary fs-6 px-3">@lastWeek صفحة</span>
                         </div>
                         @if (thisWeek > lastWeek)
                         {
                             <div class="text-center">
                                 <small class="text-muted d-block">التحسن</small>
                                 <span class="badge bg-warning text-dark fs-6 px-3"><i class="bi bi-graph-up-arrow me-1"></i> +@(thisWeek - lastWeek)</span>
                             </div>
                         }
                     </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Actions and History -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 bg-white p-4 rounded-4 h-100">
                <h6 class="fw-bold text-secondary mb-4 border-bottom pb-2">إجراءات سريعة</h6>
                <div class="d-grid gap-3">
                    <a asp-action="PrintStudentReport" asp-route-id="@Model.Id" class="btn btn-danger py-3 rounded-4 shadow-sm">
                        <i class="bi bi-file-earmark-pdf-fill fs-5 me-2"></i> طباعة تقرير PDF
                    </a>
                    <a asp-controller="Memorizations" asp-action="DailyRecord" class="btn btn-outline-primary py-3 rounded-4">
                        <i class="bi bi-plus-circle me-2"></i> تسجيل تسميع جديد
                    </a>
                </div>

                <h6 class="fw-bold text-secondary mt-5 mb-3 border-bottom pb-2">آخر إنجاز</h6>
                @{
                    var lastMem = Model.Memorizations?.OrderByDescending(m => m.Date).FirstOrDefault();
                }
                @if (lastMem != null)
                {
                    <div class="p-3 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-4">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold text-success">سورة @lastMem.SurahName</span>
                            <small class="text-muted">@lastMem.Date.ToShortDateString()</small>
                        </div>
                        <p class="mb-0 small text-dark">من آية @lastMem.FromAyah إلى @lastMem.ToAyah</p>
                        <div class="mt-2 text-end">
                            <span class="badge bg-success rounded-pill">@lastMem.Grade</span>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-4 small italic">لا توجد سجلات حفظ مضافة بعد</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('progressChart').getContext('2d');
        const progressChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['الأسبوع الماضي', 'هذا الأسبوع'],
                datasets: [{
                    label: 'عدد الصفحات المنجزة',
                    data: [@lastWeek.ToString().Replace(",", "."), @thisWeek.ToString().Replace(",", ".")],
                    backgroundColor: [
                        'rgba(54, 162, 235, 0.7)', // Blue
                        'rgba(75, 192, 192, 0.7)'  // Green
                    ],
                    borderColor: [
                        'rgba(54, 162, 235, 1)',
                        'rgba(75, 192, 192, 1)'
                    ],
                    borderWidth: 2,
                    borderRadius: 10,
                    barThickness: 60
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        rtl: true,
                        titleFont: { family: 'Cairo, sans-serif' },
                        bodyFont: { family: 'Cairo, sans-serif' }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            display: false
                        },
                        ticks: {
                            precision: 1
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    </script>
}
