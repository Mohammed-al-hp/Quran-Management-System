@model IEnumerable<QuranCenters.Core.Entities.Student>

@{
    ViewData["Title"] = "????? ??????";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="card shadow-sm border-0 bg-white p-4 rounded" style="border-radius: 15px !important;">

        @* ??????? ??? ??????? *@
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <div>
                <h4 class="m-0 text-success fw-bold">????? ???? ??????</h4>
                <p class="text-muted mb-0 small">??? ?????? ?????? ???? ??????</p>
            </div>
            <a asp-controller="Students" asp-action="Create" class="btn btn-success d-flex align-items-center gap-2 px-4 shadow-sm">
                <i class="bi bi-person-plus-fill"></i> ????? ???? ????
            </a>
        </div>

        @* ??? ??????? ?????? *@
        <div class="row g-3 mb-4">
            <div class="col-md-5">
                <label class="form-label small fw-bold text-muted">????? ??????:</label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control border-start-0 bg-white" placeholder="???? ???? ??????...">
                </div>
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold text-muted">????? ??? ??????:</label>
                <form method="get" asp-action="Index" id="filterForm">
                    <select name="circleId" class="form-select bg-white shadow-sm" onchange="document.getElementById('filterForm').submit()">
                        <option value="">-- ??? ???? ??????? --</option>
                        @foreach (var circle in (IEnumerable<QuranCenters.Core.Entities.Circle>)ViewBag.Circles)
                        {
                            <!option value="@circle.Id" @(ViewBag.SelectedCircle == circle.Id ? "selected" : "")>
