            </div>

            <div class="col-md-3 d-flex align-items-end justify-content-md-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm" title="????? ?????">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>
                <button class="btn btn-outline-dark px-3 shadow-sm" onclick="window.print()">
                    <i class="bi bi-printer"></i> ?????
                </button>
            </div>
        </div>

        @* ?????? *@
        <div class="table-responsive">
            <table class="table table-hover align-middle" id="studentsTable">
                <thead class="table-light">
                    <tr>
                        <th class="py-3 px-3">??? ??????</th>
                        <th class="py-3 text-center">????? ????????</th>
                        <th class="py-3 text-center">??????</th>
                        <th class="py-3 text-center">??????</th>
                        <th class="py-3 text-center" style="min-width: 150px;">?????????</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr class="no-data-row">
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-info-circle d-block mb-2" style="font-size: 2rem;"></i>
                                ?? ???? ???? ?????? ?? ??? ?????? ??????.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark px-3">@item.Name</td>
                                <td class="text-center text-muted">@item.JoinDate.ToShortDateString()</td>
                                <td class="text-center">
                                    <span class="badge bg-soft-success text-success px-3 py-2 border">
                                        @(item.Circle?.Name ?? "???? ????")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.Status == "???")
                                    {
                                        <span class="badge bg-success rounded-pill px-3 shadow-sm">???</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 shadow-sm">??? ???</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-circle" title="?????">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @* ?? ????? ?????? ????? ?? ???? ????? ??? PDF *@
                                        <a asp-controller="Students" asp-action="PrintStudentReport" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-circle" title="????? ????? PDF">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>

                                        @if (User.IsInRole("Admin") || User.IsInRole("???? ??????"))
                                        {
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('?? ??? ????? ?? ??? ??? ?????? ????????')" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="???">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* ????????? ??????? ??? ???? ?? ?????? */
    .bg-soft-success {
        background-color: #e8f5e9 !important;
        border: 1px solid #c8e6c9 !important;
    }

    .table thead th {
        font-size: 0.9rem;
        font-weight: 600;
        color: #495057;
        background-color: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

    .btn-sm.rounded-circle {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .btn-sm.rounded-circle:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    /* ????? ??? ??????? */
    @@media print {
        .btn, .input-group, #filterForm, label, .text-muted {
            display: none !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
            padding: 0 !important;
        }

        .table {
            width: 100% !important;
            border: 1px solid #000;
        }

        th, td {
            border: 1px solid #dee2e6 !important;
        }
    }
</style>

@section Scripts {
    <script>
        // ?????? ????? ?????? ???????
        document.getElementById("searchInput").addEventListener("keyup", function () {
            var filter = this.value.toLowerCase();
            var rows = document.querySelectorAll("#studentsTable tbody tr:not(.no-data-row):not(.no-result-row)");
            var visibleCount = 0;

            rows.forEach(row => {
                var nameText = row.cells[0].textContent.toLowerCase();
                if (nameText.includes(filter)) {
                    row.style.display = "";
                    visibleCount++;
                } else {
                    row.style.display = "none";
                }
            });

            // ????? ????? "?? ???? ?????" ??? ?????
            var existingMsg = document.getElementById("noResultMsg");
            if (visibleCount === 0 && filter !== "") {
                if (!existingMsg) {
                    var tbody = document.querySelector("#studentsTable tbody");
                    var row = tbody.insertRow();
                    row.id = "noResultMsg";
                    row.className = "no-result-row";
                    row.innerHTML = `<td colspan="5" class="text-center py-4 text-danger fw-bold">?? ???? ????? ??? ?????? ??: "${filter}"</td>`;
                }
            } else if (existingMsg) {
                existingMsg.remove();
            }
        });
    </script>
}