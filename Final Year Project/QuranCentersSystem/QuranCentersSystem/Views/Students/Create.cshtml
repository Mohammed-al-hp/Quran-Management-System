@model QuranCentersSystem.Models.Student

@{
    ViewData["Title"] = "إضافة طالب جديد";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/material_green.css">
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    /* تنسيق لضمان محاذاة النصوص والعناوين لليمين بشكل صارم */
    .text-end {
        text-align: right !important;
    }

    .form-label {
        display: block;
        text-align: right;
        width: 100%;
        margin-bottom: 8px;
    }

    /* تعديل لبرواز Select2 ليدعم العربية والارتفاع المتناسق */
    .select2-container--default .select2-selection--single {
        border: 2px solid #dee2e6 !important;
        border-radius: 12px !important;
        height: 45px !important;
        line-height: 45px !important;
    }

    .select2-container[dir="rtl"] .select2-selection--single .select2-selection__arrow {
        left: 10px !important;
        right: auto !important;
    }
</style>

<div class="container py-5" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                <div class="card-header border-0 py-4 text-white text-center" style="background-color: #1a531a;">
                    <h3 class="fw-bold mb-0"><i class="bi bi-person-plus-fill ms-2"></i> إضافة طالب جديد للمنظومة</h3>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Create" method="post" enctype="multipart/form-data" id="createForm">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger mb-3 text-end fw-bold"></div>

                        <div class="mb-5">
                            <h5 class="fw-bold text-success border-bottom pb-2 mb-4 text-end">
                                <i class="bi bi-shield-lock ms-2"></i> بيانات الحساب (للدخول للنظام)
                            </h5>
                            <div class="row g-4">
                                <div class="col-md-6 text-end">
                                    <label class="form-label fw-bold">اسم المستخدم <span class="text-danger">*</span></label>
                                    <input asp-for="Username" id="generatedUsername" class="form-control form-control-lg border-2 shadow-sm" style="border-radius:12px" placeholder="يتم التوليد تلقائياً..." required />
                                    <span asp-validation-for="Username" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 text-end">
                                    <label class="form-label fw-bold">كلمة المرور <span class="text-danger">*</span></label>
                                    <input asp-for="Password" id="generatedPassword" type="text" class="form-control form-control-lg border-2 shadow-sm" style="border-radius:12px" placeholder="يتم التوليد تلقائياً..." required />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                            <h5 class="fw-bold text-success border-bottom pb-2 mb-4 text-end">
                                <i class="bi bi-person-badge ms-2"></i> بيانات الطالب الشخصية
                            </h5>
                            <div class="row g-4">
                                <div class="col-md-8 text-end">
                                    <label asp-for="Name" class="form-label fw-bold">اسم الطالب الرباعي <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control form-control-lg border-2" style="border-radius:12px" placeholder="الاسم الكامل" />
                                </div>
                                <div class="col-md-4 text-end">
                                    <label class="form-label fw-bold">السورة الحالية</label>
                                    <input asp-for="CurrentSurah" class="form-control form-control-lg border-2" style="border-radius:12px" placeholder="مثلاً: سورة البقرة" />
                                </div>
                                <div class="col-md-6 text-end">
                                    <label asp-for="Phone" class="form-label fw-bold">رقم هاتف الطالب</label>
                                    <input asp-for="Phone" class="form-control form-control-lg border-2" style="border-radius:12px" />
                                </div>
                                <div class="col-md-6 text-end">
                                    <label asp-for="BirthDate" class="form-label fw-bold">تاريخ الميلاد <span class="text-danger">*</span></label>
                                    <input asp-for="BirthDate" type="text" id="birthDatePicker" class="form-control form-control-lg border-2 bg-white" style="border-radius:12px" readonly />
                                </div>
                                <div class="col-md-12 text-end">
                                    <label asp-for="CircleId" class="form-label fw-bold">الحلقة التنسيبية <span class="text-danger">*</span></label>
                                    <select asp-for="CircleId" class="form-select form-select-lg border-2" style="border-radius:12px" asp-items="ViewBag.CircleId">
                                        <option value="">-- اختر الحلقة --</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mb-5 p-4 rounded-4" style="background-color: #f8fcf8; border: 1px dashed #1a531a;">
                            <h5 class="fw-bold text-success mb-4 text-end"><i class="bi bi-people ms-2"></i> بيانات ولي الأمر</h5>

                            <div id="existingParentDiv" class="mb-4 text-end">
                                <label class="form-label fw-bold">البحث عن ولي أمر مسجل مسبقاً</label>
                                <select asp-for="ParentId" class="form-select select2-parent" asp-items="ViewBag.ParentId">
                                    <option value="">-- ابحث بالاسم أو الرقم --</option>
                                </select>
                            </div>

                            <div class="text-center mb-4">
                                <button type="button" class="btn btn-sm btn-outline-success rounded-pill" onclick="toggleParentForm()">
                                    <i class="bi bi-plus-circle ms-1"></i> إضافة ولي أمر جديد غير موجود بالقائمة
                                </button>
                            </div>

                            <div id="newParentForm" style="display:none;" class="bg-white p-3 rounded-3 shadow-sm border text-end">
                                <h6 class="fw-bold mb-3 text-primary">تعبئة بيانات ولي أمر جديد:</h6>
                                <div class="row g-3">
                                    <div class="col-md-5">
                                        <input name="NewParentName" class="form-control" placeholder="اسم ولي الأمر" />
                                    </div>
                                    <div class="col-md-4">
                                        <input name="NewParentPhone" class="form-control" placeholder="رقم الهاتف" />
                                    </div>
                                    <div class="col-md-3">
                                        <select name="ParentRelation" class="form-select text-muted">
                                            <option value="">صلة القرابة</option>
                                            <option value="أب">أب</option>
                                            <option value="أم">أم</option>
                                            <option value="قريب">قريب / وصي</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-5 text-end">
                            <h5 class="fw-bold text-success border-bottom pb-2 mb-4"><i class="bi bi-image ms-2"></i> صورة الطالب (اختيارية)</h5>
                            <div class="input-group">
                                <input type="file" name="StudentPhoto" class="form-control form-control-lg border-2 shadow-sm" style="border-radius:12px" accept="image/*" />
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-4 justify-content-end">
                            <button type="submit" class="btn btn-lg text-white px-5 shadow-sm" style="background-color: #1a531a; border-radius: 12px; min-width: 200px;">
                                <i class="bi bi-save ms-2"></i> حفظ الطالب
                            </button>
                            <a asp-action="Index" class="btn btn-lg btn-outline-secondary px-4 shadow-sm" style="border-radius: 12px;">إلغاء</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/ar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            // توليد بيانات الحساب تلقائياً
            generateAccountDefaults();

            // تفعيل Select2 لولي الأمر
            $('.select2-parent').select2({
                placeholder: "ابحث عن ولي الأمر...",
                dir: "rtl",
                width: '100%'
            });

            // تفعيل Flatpickr للتاريخ
            flatpickr("#birthDatePicker", {
                locale: "ar",
                dateFormat: "Y-m-d",
                maxDate: "today",
                disableMobile: true
            });
        });

        function generateAccountDefaults() {
            const randomNum = Math.floor(1000 + Math.random() * 9000);
            const currentYear = new Date().getFullYear();
            const usernameField = document.getElementById('generatedUsername');
            const passwordField = document.getElementById('generatedPassword');

            if (usernameField && !usernameField.value) {
                usernameField.value = "student_" + currentYear + "_" + randomNum;
            }

            if (passwordField && !passwordField.value) {
                passwordField.value = "St" + String.fromCharCode(64) + randomNum;
            }
        }

        function toggleParentForm() {
            var form = document.getElementById('newParentForm');
            var selectDiv = document.getElementById('existingParentDiv');
            var selectElement = $('.select2-parent');

            if (form.style.display === "none" || form.style.display === "") {
                form.style.display = "block";
                selectDiv.style.opacity = "0.5";
                selectElement.val(null).trigger('change');
            } else {
                form.style.display = "none";
                selectDiv.style.opacity = "1";
            }
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}