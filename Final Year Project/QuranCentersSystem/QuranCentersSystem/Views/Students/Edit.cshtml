@model QuranCenters.Core.Entities.Student

@{
    ViewData["Title"] = "تعديل بيانات طالب";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="card shadow-sm bg-white p-4 rounded-3 border-0">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <div>
                <h4 class="m-0 text-success fw-bold">تعديل ملف الطالب</h4>
                <p class="text-muted small mb-0">تحديث المعلومات الأساسية والحالة الأكاديمية للطالب</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm">
                <i class="bi bi-arrow-right me-1"></i> عودة للقائمة
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <form asp-action="Edit" class="bg-light p-4 rounded-4 shadow-sm border-0">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    @* اسم الطالب *@
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold text-secondary">اسم الطالب</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="bi bi-person"></i></span>
                            <input asp-for="Name" class="form-control border-0 shadow-sm py-2" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    @* الحلقة *@
                    <div class="mb-3">
                        <label asp-for="CircleId" class="form-label fw-bold text-secondary">الحلقة الدراسية</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="bi bi-mortarboard"></i></span>
                            <select asp-for="CircleId" class="form-select border-0 shadow-sm py-2" asp-items="ViewBag.CircleId">
                                <option value="">-- اختر الحلقة --</option>
                            </select>
                        </div>
                        <span asp-validation-for="CircleId" class="text-danger small"></span>
                    </div>

                    @* تاريخ الانضمام *@
                    <div class="mb-3">
                        <label asp-for="JoinDate" class="form-label fw-bold text-secondary">تاريخ الانضمام</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="bi bi-calendar-date"></i></span>
                            <input asp-for="JoinDate" type="date" class="form-control border-0 shadow-sm py-2" />
                        </div>
                        <span asp-validation-for="JoinDate" class="text-danger small"></span>
                    </div>

                    @* حالة الطالب *@
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-bold text-secondary">حالة الطالب</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="bi bi-shield-check"></i></span>
                            <select asp-for="Status" class="form-select border-0 shadow-sm py-2">
                                <option value="نشط">نشط</option>
                                <option value="غير نشط">غير نشط</option>
                            </select>
                        </div>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <hr class="my-4 opacity-25">

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-warning btn-lg py-3 shadow-sm fw-bold">
                            <i class="bi bi-check-circle me-1"></i> حفظ التعديلات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}