@model QuranCenters.Core.Entities.Student

@{
    Layout = null; // ??????? ?? ????? ????? ?????? ????? ???????
}

<html dir="rtl">
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
        }

        .header-box {
            border-bottom: 2px solid #28a745;
            margin-bottom: 30px;
            padding-bottom: 10px;
        }

        .stat-box {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background-color: #28a745;
            color: white;
        }
    </style>
</head>
<body>
    <div class="header-box text-center">
        <h2>????? ?????? ????</h2>
        <h4>@Model.FullName</h4>
    </div>

    <div class="row">
        <div class="col-6">
            <div class="stat-box">
                <strong>?????? ???? ??????:</strong> @Model.Attendances.Count(a => a.Status == "????")
            </div>
        </div>
        <div class="col-6">
            <div class="stat-box">
                <strong>??? ???? ?? ?????:</strong> @Model.Memorizations.OrderByDescending(m => m.Date).FirstOrDefault()?.SurahName
            </div>
        </div>
    </div>

    <h5 class="mt-4">??? ??????? ??????</h5>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>???????</th>
                <th>??? ???????</th>
                <th>??????</th>
                <th>???????</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Memorizations.OrderByDescending(m => m.Date).Take(10))
            {
                <tr>
                    <td>@item.Date.ToShortDateString()</td>
                    <td>@item.Type</td>
                    <td>@item.SurahName (@item.Scope)</td>
                    <td>@item.Grade</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-5 text-start">
        <p>??? ??????: ........................</p>
    </div>
</body>
</html>