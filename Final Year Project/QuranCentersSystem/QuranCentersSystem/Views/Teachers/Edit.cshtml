@model QuranCentersSystem.Models.Teacher

@{
    ViewData["Title"] = "تعديل بيانات المحفظ";
}

<div class="container py-4" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-pencil-square"></i> تعديل بيانات: @Model.Name
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">اسم المحفظ</label>
                            <input asp-for="Name" class="form-control" placeholder="أدخل الاسم الرباعي" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">رقم الهاتف</label>
                            <input asp-for="Phone" class="form-control" placeholder="09XXXXXXXX" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Qualification" class="form-label fw-bold">المؤهل / الإجازة</label>
                            <input asp-for="Qualification" class="form-control" placeholder="مثلاً: إجازة في رواية قالون" />
                            <span asp-validation-for="Qualification" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning px-4 fw-bold">حفظ التعديلات</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}